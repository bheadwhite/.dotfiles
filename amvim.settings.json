{
  "workbench.colorTheme": "gruvboxConcoctis dark hard",
  "diffEditor.renderSideBySide": true,
  "editor.cursorSmoothCaretAnimation": true,
  "breadcrumbs.showFields": false,
  "breadcrumbs.showConstants": false,
  "breadcrumbs.showKeys": false,
  "breadcrumbs.showConstructors": false,
  "breadcrumbs.symbolPath": "on",
  "breadcrumbs.showProperties": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "amVim.mimicVimSearchBehavior": true,
  "amVim.vimStyleNavigationInListView": true,
  "editor.cursorBlinking": "phase",
  "editor.formatOnSave": true,
  "editor.cursorSurroundingLines": 5,
  "editor.fontFamily": "Fira Code",
  "editor.fontSize": 14,
  "editor.minimap.enabled": false,
  "editor.minimap.maxColumn": 100,
  "editor.minimap.size": "fill",
  "editor.tabSize": 2,
  "gitlab.instanceUrl": "https://git.tcncloud.net",
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "javascript.preferences.quoteStyle": "single",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "prettier.jsxBracketSameLine": true,
  "prettier.jsxSingleQuote": true,
  "prettier.singleQuote": true,
  "prettier.tabWidth": 2,
  "prettier.trailingComma": "all",
  "prettier.useEditorConfig": false,
  "scoper.braces": false,
  "scoper.endColor": "#1170ff80",
  "scoper.highlightColor": "",
  "scoper.parentheses": false,
  "scoper.squareBrackets": false,
  "telemetry.enableCraskhReporter": false,
  "telemetry.enableTelemetry": false,
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.tsserver.log": "off",
  "typescript.preferences.quoteStyle": "single",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "workbench.activityBar.visible": false,
  "workbench.editor.labelFormat": "short",
  "workbench.settings.editor": "json",
  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": false,
  "zenMode.hideTabs": false,

  "gitlens.codeLens.enabled": false,
  "gitlens.statusBar.enabled": false,
  "editor.lineNumbers": "on",
  "workbench.colorCustomizations": {
    "editor.selectionBackground": "#ffffff23",
    "editor.rangeHighlightBackground": "#ffffff23",
    "tab.activeBorder": "#40ff01",
    "editorBracketMatch.background": "#1170ff88",
    "editorBracketMatch.border": "#ff8400",
    "editor.wordHighlightStrongBackground": "#3e4998",
    "editor.wordHighlightBackground": "#3e4998",
    "editor.findMatchBackground": "#282c34",
    "editor.findMatchHighlightBackground": "#06570997",
    "editor.selectionForeground": "#99eeff",
    "editorIndentGuide.activeBackground": "#1d76db",
    "list.inactiveSelectionForeground": "#fff",
    "list.activeSelectionForeground": "#fff",
    "list.activeSelectionBackground": "#26007e",
    "list.focusBackground": "#2e5704",
    "terminal.border": "#ff0000"
  },
  "macros.list": {
    "shiftTo1": [
      "workbench.action.focusFirstEditorGroup",
      "workbench.action.closeSidebar"
    ],
    "shiftToSideBar": [
      "workbench.action.focusSideBar",
      "workbench.action.focusSideBar"
    ],
    "copycopy": [
      "copy-copy-paste.copy",
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      {
        "command": "type",
        "args": {
          "text": "y"
        }
      }
    ],
    "p-Paste": ["editor.action.clipboardPasteAction"],
    "goPrevChange": [
      "workbench.action.editor.previousChange",
      "editor.action.dirtydiff.previous"
    ],
    "goNextChange": [
      "workbench.action.editor.nextChange",
      "editor.action.dirtydiff.next"
    ],
    "selectInnerWord": [
      {
        "command": "type",
        "args": {
          "text": "v"
        }
      },
      {
        "command": "type",
        "args": {
          "text": "i"
        }
      },
      {
        "command": "type",
        "args": {
          "text": "w"
        }
      }
    ],
    "customSwitchAppHack": ["workbench.action.terminal.focus"],
    "customFindInFiles": [
      "workbench.action.findInFiles",
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      "list.focusDown"
    ],
    "customScmFocus": [
      "workbench.action.focusSideBar",
      "list.focusDown",
      "list.focusUp"
    ],
    "customY": [
      "copy-copy-paste.copy",
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      {
        "command": "type",
        "args": {
          "text": "y"
        }
      }
    ],
    "customJ": [
      {
        "command": "type",
        "args": {
          "text": ""
        }
      },
      "workbench.action.focusFirstEditorGroup"
    ],
    "indentSelectToBeginning": [
      "cursorEnd",
      {
        "command": "type",
        "args": {
          "text": "V"
        }
      },
      "indentation-level-movement.selectUp",
      {
        "command": "type",
        "args": {
          "text": "0"
        }
      }
    ],
    "indentSelectToEnd": [
      {
        "command": "type",
        "args": {
          "text": "V"
        }
      },
      "indentation-level-movement.selectDown",
      "cursorEndSelect"
    ]
  },
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
    "typescriptreact": "javascriptreact",
    "jsx-sublime-babel-tags": "javascriptreact"
  },
  "gitlens.menus": {
    "editor": false,
    "editorGroup": false,
    "editorTab": false,
    "explorer": {
      "clipboard": true,
      "compare": true,
      "history": true,
      "remote": true
    },
    "scmGroup": {
      "compare": true,
      "openClose": true,
      "stash": true,
      "stashInline": true
    },
    "scmItem": {
      "clipboard": true,
      "compare": true,
      "history": true,
      "remote": true,
      "stash": true
    }
  },
  "gitlab.customQueries": [
    {
      "name": "Issues assigned to me",
      "type": "issues",
      "scope": "assigned_to_me",
      "state": "opened",
      "noItemText": "There is no issue assigned to you."
    },
    {
      "name": "Merge requests assigned to me",
      "type": "merge_requests",
      "scope": "assigned_to_me",
      "state": "opened",
      "noItemText": "There is no MR assigned to you."
    }
  ],
  "editor.quickSuggestions": {
    "other": false,
    "comments": false,
    "strings": false
  },
  "workbench.iconTheme": "eq-material-theme-icons-ocean",
  "helium-icon-theme.hidesExplorerArrows": true,
  "helium-icon-theme.saturation": 1,
  "helium-icon-theme.folders.theme": "specific",
  "helium-icon-theme.opacity": 1,
  "gitlens.mode.active": "zen",
  "twlight.enabled": true
}
