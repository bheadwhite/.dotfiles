{
  "amVim.useSystemClipboard": true,
  "breadcrumbs.icons": false,
  "breadcrumbs.symbolSortOrder": "position",
  "clipboard-manager.avoidDuplicates": true,
  "clipboard-manager.maxClips": 500,
  "clipboard-manager.moveToTop": true,
  "clipboard-manager.onlyWindowFocused": false,
  "clipboard-manager.snippet.enabled": false,
  "diffEditor.renderIndicators": false,
  "diffEditor.renderSideBySide": true,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": true,
  "editor.cursorSurroundingLines": 5,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.definitionLinkOpensInPeek": false,
  "editor.experimental.stickyScroll.enabled": true,
  "editor.find.autoFindInSelection": "multiline",
  "editor.find.cursorMoveOnType": true,
  "editor.fontFamily": "Fira Code",
  "editor.fontSize": 14,
  "editor.formatOnSave": true,
  "editor.glyphMargin": false,
  "editor.gotoLocation.alternativeDefinitionCommand": "editor.action.referenceSearch.trigger",
  "editor.guides.bracketPairs": true,
  "editor.guides.bracketPairsHorizontal": false,
  "editor.guides.highlightActiveBracketPair": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.inlayHints.enabled": "on",
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.minimap.maxColumn": 100,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.showSlider": "always",
  "editor.minimap.size": "fill",
  "editor.multiCursorModifier": "alt",
  "editor.parameterHints.enabled": false,
  "editor.scrollbar.verticalScrollbarSize": 12,
  "editor.smoothScrolling": false,
  "editor.snippetSuggestions": "bottom",
  "editor.suggest.localityBonus": true,
  "editor.suggest.showSnippets": false,
  "editor.suggestOnTriggerCharacters": false,
  "editor.suggestSelection": "recentlyUsed",
  "editor.tabCompletion": "off",
  "editor.tabSize": 2,
  "editor.wordBasedSuggestions": false,
  "editor.wordBasedSuggestionsMode": "currentDocument",
  "emmet.showSuggestionsAsSnippets": true,
  "everforest.darkContrast": "hard",
  "everforest.darkCursor": "yellow",
  "everforest.darkSelection": "aqua",
  "everforest.italicKeywords": true,
  "explorer.compactFolders": false,
  "explorer.openEditors.visible": 0,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.mergeEditor": false,
  "git.openDiffOnClick": true,
  "gitlens.codeLens.authors.enabled": false,
  "gitlens.codeLens.recentChange.enabled": false,
  "gitlens.statusBar.enabled": false,
  "http.systemCertificates": true,
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "javascript.preferences.jsxAttributeCompletionStyle": "auto",
  "javascript.preferences.quoteStyle": "single",
  "javascript.suggest.names": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "liveshare.audio.joinCallBehavior": "accept",
  "problems.sortOrder": "position",
  "screencastMode.onlyKeyboardShortcuts": true,
  "search.searchOnType": false,
  "security.workspace.trust.untrustedFiles": "open",
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.tabs.enabled": false,
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.preferences.jsxAttributeCompletionStyle": "auto",
  "typescript.preferences.quoteStyle": "single",
  "typescript.preferences.useAliasesForRenames": false,
  "typescript.referencesCodeLens.showOnAllFunctions": true,
  "typescript.suggest.classMemberSnippets.enabled": false,
  "typescript.tsserver.log": "off",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "workbench.activityBar.visible": false,
  "workbench.colorTheme": "Everforest Dark",
  "workbench.editor.enablePreviewFromCodeNavigation": true,
  "workbench.editor.labelFormat": "short",
  "workbench.iconTheme": "eq-material-theme-icons-darker",
  "workbench.list.automaticKeyboardNavigation": false,
  "workbench.panel.defaultLocation": "bottom",
  "workbench.panel.opensMaximized": "never",
  "workbench.settings.editor": "json",
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.sideBar.location": "left",
  "workbench.startupEditor": "none",
  "zenMode.centerLayout": false,
  "editor.unicodeHighlight.allowedCharacters": {
    "–": true
  },
  "macros.list": {
    "openScmFile": ["git.openFile", "git.closeAllDiffEditors"],
    "cursorJumpDown": [
      {
        "command": "type",
        "args": {
          "text": "5"
        }
      },
      "amVim.down"
    ],
    "cursorJumpUp": [
      {
        "command": "type",
        "args": {
          "text": "5"
        }
      },
      "amVim.up"
    ],
    "newLine": [
      {
        "command": "type",
        "args": {
          "text": "\n"
        }
      }
    ],
    "closeQuickOpen": [
      "workbench.action.closeQuickOpen",
      "workbench.action.focusActiveEditorGroup"
    ],
    "goPrevChange": [
      "workbench.action.editor.previousChange",
      "editor.action.dirtydiff.previous"
    ],
    "goNextChange": [
      "workbench.action.editor.nextChange",
      "editor.action.dirtydiff.next"
    ],
    "cDeleteText": [
      "deleteInsideWord",
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      {
        "command": "type",
        "args": {
          "text": "i"
        }
      }
    ],
    "indentSelectToEnd": [
      {
        "command": "type",
        "args": {
          "text": "V"
        }
      },
      "indentation-level-movement.selectDown",
      "cursorEndSelect"
    ],
    "gitViewFile": [
      "list.selectAndPreserveFocus",
      {
        "command": "$delay",
        "args": {
          "delay": 50
        }
      },
      "workbench.action.focusFirstEditorGroup"
    ],
    "resetTree": [
      "workbench.files.action.collapseExplorerFolders",
      "workbench.files.action.refreshFilesExplorer"
    ]
  },
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
    "typescriptreact": "javascriptreact",
    "jsx-sublime-babel-tags": "javascriptreact"
  },
  "gitlens.menus": {
    "editor": false,
    "editorGroup": false,
    "editorTab": false,
    "explorer": {
      "clipboard": true,
      "compare": true,
      "history": true,
      "remote": true
    },
    "scmGroup": {
      "compare": true,
      "openClose": true,
      "stash": true,
      "stashInline": true
    },
    "scmItem": {
      "clipboard": true,
      "compare": true,
      "history": true,
      "remote": true,
      "stash": true
    }
  },
  "workbench.colorCustomizations": {
    // everforest colors
    //   'red': "#e67e80"
    //   'orange': "#e69875"
    //   'yellow': "#dbbc7f"
    //   'green': "#a7c080"
    //   'aqua': "#83c092"
    //   'blue': "#7fbbb3"
    //   'purple': "#d699b6"
    //   'light grey0': "#7a8478"
    //   'lighter grey1': "#859289"
    //   'lightest grey2': "#9da9a0"

    "editorBracketHighlight.foreground1": "#7fbbb3", //blue
    "editorBracketHighlight.foreground2": "#e69875", //orange
    "editorBracketHighlight.foreground3": "#dbbc7f", //yellow
    "editorBracketHighlight.foreground4": "#a7c080", //green
    "editorBracketHighlight.foreground5": "#83c092", //aqua
    "editorBracketHighlight.foreground6": "#e67e80", //red

    "tab.activeBorderTop": "#ffffff",

    "editorLineNumber.activeForeground": "#c0fa2d",

    "tab.unfocusedActiveBackground": "#2b3338",
    "tab.unfocusedActiveBorder": "#2b3338",
    "tab.activeBackground": "#2b3338",
    "tab.activeBorder": "#2b3338",

    "tab.unfocusedInactiveBackground": "#131f1f",
    "tab.unfocusedActiveBorderTop": "#131f1f",
    "tab.inactiveBackground": "#131f1f",
    "sideBar.border": "#131f1f",
    "panel.border": "#131f1f",
    "tab.border": "#131f1f",

    "titleBar.activeBackground": "#000000"
  }
}
