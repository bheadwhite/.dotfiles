{
  "bookmarks.navigateThroughAllFiles": false,
  "breadcrumbs.filePath": "on",
  "breadcrumbs.icons": false,
  "breadcrumbs.symbolSortOrder": "type",
  "debug.javascript.usePreview": false,
  "diffEditor.renderSideBySide": true,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.cursorBlinking": "phase",
  "editor.foldingImportsByDefault": true,
  "editor.cursorSmoothCaretAnimation": true,
  "editor.cursorSurroundingLines": 5,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.foldingStrategy": "auto",
  "editor.fontFamily": "Fira Code",
  "editor.fontSize": 13,
  "editor.formatOnSave": true,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.minimap.maxColumn": 100,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.showSlider": "always",
  "editor.minimap.size": "fill",
  "editor.multiCursorModifier": "alt",
  "editor.parameterHints.enabled": false,
  "editor.snippetSuggestions": "bottom",
  "editor.suggestSelection": "recentlyUsed",
  "editor.tabCompletion": "off",
  "editor.tabSize": 2,
  "editor.wordBasedSuggestions": false,
  "emmet.showSuggestionsAsSnippets": true,
  "explorer.compactFolders": false,
  "explorer.openEditors.visible": 0,
  "githd.logView.displayExpressStatus": false,
  "githd.logView.expressMode": true,
  "githd.blameView.enabled": false,
  "gitlab.instanceUrl": "https://git.tcncloud.net",
  "gitlens.codeLens.enabled": false,
  "gitlens.recentChanges.highlight.locations": ["overview", "gutter", "line"],
  "gitlens.statusBar.enabled": false,
  "gitlens.views.compare.enabled": false,
  "gitlens.views.search.enabled": false,
  "go.formatTool": "goimports",
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "javascript.preferences.quoteStyle": "single",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "material-icon-theme.hidesExplorerArrows": true,
  "openInGitHub.defaultBranch": "master",
  "openInGitHub.defaultRemote": "origin",
  "openInGitHub.excludeCurrentRevision": false,
  "openInGithub.maxBuffer": 512000,
  "prettier.jsxBracketSameLine": true,
  "prettier.jsxSingleQuote": true,
  "prettier.singleQuote": true,
  "prettier.tabWidth": 2,
  "prettier.trailingComma": "all",
  "prettier.useEditorConfig": false,
  "quokka.colorizeOutput": true,
  "quokka.compactMessageOutput": true,
  "quokka.showOutputOnStart": false,
  "scoper.braces": false,
  "scoper.endColor": "#1170ff80",
  "scoper.highlightColor": "",
  "scoper.parentheses": false,
  "scoper.squareBrackets": false,
  "search.searchOnType": false,
  "telemetry.enableCraskhReporter": false,
  "telemetry.enableTelemetry": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.tabs.enabled": false,
  "turboConsoleLog.addSemicolonInTheEnd": false,
  "turboConsoleLog.includeFileNameAndLineNum": false,
  "turboConsoleLog.logMessagePrefix": "🚀",
  "turboConsoleLog.delimiterInsideMessage": ":",
  "turboConsoleLog.wrapLogMessage": false,
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.tsserver.log": "off",
  "typescript.preferences.quoteStyle": "single",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.referencesCodeLens.showOnAllFunctions": true,
  "workbench.activityBar.visible": false,
  "workbench.editor.enablePreviewFromCodeNavigation": true,
  "workbench.editor.labelFormat": "short",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.settings.editor": "json",
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.sideBar.location": "left",
  "workbench.startupEditor": "newUntitledFile",
  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": false,
  "zenMode.hideTabs": false,
  "openInApplication.applications": {
    "html": ["Google Chrome"]
  },
  "workbench.colorCustomizations": {
    "editor.selectionBackground": "#ffffff23",
    "editor.rangeHighlightBackground": "#ffffff23",
    "tab.activeBorder": "#40ff01",

    "editorBracketMatch.background": "#1170ff88",
    "editorBracketMatch.border": "#ff8400",
    "editor.wordHighlightStrongBackground": "#3e4998",
    "editor.wordHighlightBackground": "#3e4998",
    "editor.findMatchBackground": "#282c34",
    "editor.findMatchHighlightBackground": "#06570997",
    "editor.selectionForeground": "#99eeff",
    "editorIndentGuide.activeBackground": "#1d76db",
    "list.inactiveSelectionForeground": "#fff",
    "list.activeSelectionForeground": "#fff",
    "list.activeSelectionBackground": "#26007e",
    "list.focusBackground": "#2e5704",
    "terminal.border": "#ff0000"
  },
  "files.exclude": {
    "**/*.go": true,
    "**/go.mod": true,
    "**/go.sum": true,
    "services/**": true,
    "**/.git/objects/**": true,
    ".plz_clean*/**": true,
    //please out stuff
    "plz-out/bin/**": true,
    "plz-out/gen/**": true,
    "plz-out/go/**": true,
    "plz-out/google/**": true,
    "plz-out/googleapis/**": true,
    //unused stuff --- start
    ".yarn": true,
    ".gitlab": true,
    "k8s/**": true,
    "opctl/**": true,
    "persist/**": true,
    "scripts/**": true,
    ".npmrc": true,
    ".nvmrc": true,
    "docs/**": true,
    "config/**": true,
    "commons/**": true,
    "devops/**": true,
    // "dist/**": true,
    "build_defs/**": true,
    "test_helpers/**": true,
    // "tools/**": true,
    "third_party/**": true,
    "protos/api/*": false,
    //protos
    "protos/bb/**": true,
    "protos/commons/**": true,
    "protos/go/**": true,
    "protos/java/**": true,
    "protos/matrix/**": true,
    "protos/p3/**": true,
    "protos/.editorconfig/**": true,
    "protos/.gitignore/**": true,
    "protos/BUILD.plz": true,

    //apps i dont work in --------------------------------------- start

    //                                          -- lms apps (dev-level-midnight) --
    // "operator/src/apps/lms/**": true,
    "operator/src/apps/cjs/**": true,
    "operator/src/apps/compliance/**": true,
    "operator/src/apps/payments/**": true,
    // ^

    // "operator/src/apps/business-intelligence/**": true,
    // "operator/src/apps/integrations/**": true,

    //                                          -- org apps (OTR) --
    // "operator/src/apps/agentManager/**": true,
    // V
    "operator/src/apps/organization/**": true,
    "operator/src/apps/huntgroupscripts/**": true,
    "operator/src/apps/room303/**": true,
    "operator/src/apps/customerSupport/**": true,

    //    V                                     -- agent apps (curious george) --

    "operator/src/apps/agent/**": true,
    "operator/src/apps/analytics/**": true,
    "operator/src/apps/omniBroadcast/**": true,
    "operator/src/apps/webphone/**": true,

    //                                         -- wfm apps (argus) --
    // "operator/src/apps/wfm/**": true,
    "operator/src/apps/manager/**": true,
    // "operator/src/apps/voiceanalytics/**": true,
    // "operator/src/apps/omniagent/**": true,

    // apps i dont work in ----------------------------------------- end

    //unused stuff ---end
    "**/.git/subtree-cache/**": true,
    "**/*.js": {
      "when": "$(basename).ts"
    },
    "**/tmp/**": true,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/bower_components": true,
    "report*": true,
    "**/log/**": true,
    "**/.fdk/**": true,
    "**/.cache/**": true
  },
  "files.watcherExclude": {
    "**/.cache/**": true,
    "**/build_defs/**": true,
    "**/commons/**": true,
    "**/protos/matrix/**": true,
    "**/protos/p3/**": true,
    "**/.git/objects/**": true,
    "**/opctl/**": true,
    "**/services/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/tmp/**": true,
    "**/*.go": true,
    "**/.yarn/**": true,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/bower_components": true,
    // "**/dist/**": true,
    // "**/log/**": true,
    // "**/logs/**": true,
    "**/.fdk/**": true,
    "**/plz-out/**": true,
    "**/public/**": true
  },
  "search.exclude": {
    "**/.cache/**": true,
    "**/*.go": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/tmp/**": true,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/bower_components": true,
    "**/dist/**": true,
    "**/log/**": true
  },
  "macros.list": {
    "shiftTo1": [
      "workbench.action.focusFirstEditorGroup",
      "workbench.action.closeSidebar"
    ],
    "shiftToSideBar": [
      "workbench.action.focusSideBar",
      "workbench.action.focusSideBar"
    ],
    "copycopy": [
      "copy-copy-paste.copy",
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      {
        "command": "type",
        "args": {
          "text": "y"
        }
      }
    ],
    "p-Paste": ["editor.action.clipboardPasteAction"],
    "goPrevChange": [
      "workbench.action.editor.previousChange",
      "editor.action.dirtydiff.previous"
    ],
    "goNextChange": [
      "workbench.action.editor.nextChange",
      "editor.action.dirtydiff.next"
    ],
    "selectInnerWord": [
      {
        "command": "type",
        "args": {
          "text": "v"
        }
      },
      {
        "command": "type",
        "args": {
          "text": "i"
        }
      },
      {
        "command": "type",
        "args": {
          "text": "w"
        }
      }
    ],
    "customSwitchAppHack": ["workbench.action.terminal.focus"],
    "customFindInFiles": [
      "workbench.action.findInFiles",
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      "list.focusDown"
    ],
    "customScmFocus": [
      "workbench.action.focusSideBar",
      "list.focusDown",
      "list.focusUp"
    ],
    "customY": [
      "copy-copy-paste.copy",
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      {
        "command": "type",
        "args": {
          "text": "y"
        }
      }
    ],
    "customJ": [
      {
        "command": "type",
        "args": {
          "text": ""
        }
      },
      "workbench.action.focusFirstEditorGroup"
    ],
    "indentSelectToBeginning": [
      "cursorEnd",
      "indentation-level-movement.selectUp",
      {
        "command": "type",
        "args": {
          "text": "0"
        }
      }
    ],
    "indentSelectToEnd": [
      {
        "command": "type",
        "args": {
          "text": "V"
        }
      },
      "indentation-level-movement.selectDown",
      "cursorEndSelect"
    ]
  },
  "settings.cycle": [
    {
      "id": "termOff",
      "overrideWorkspaceSettings": true,
      "values": [
        // "editorBracketMatch.background": "#f008",
        {
          "workbench.colorCustomizations": {
            "editor.selectionBackground": "#ffffff23",
            "editor.rangeHighlightBackground": "#ffffff23",
            // "editorBracketMatch.background": "#1fe609",
            // "editorBracketMatch.border": "#f00",
            "editorBracketMatch.background": "#F008",
            "editorBracketMatch.border": "#999",
            "editor.wordHighlightStrongBackground": "#3e4998",
            "editor.wordHighlightBackground": "#3e4998",
            "editor.findMatchBackground": "#282c34",
            "editor.findMatchHighlightBackground": "#06570997",
            "editor.selectionForeground": "#99eeff",
            "editorIndentGuide.activeBackground": "#1d76db",
            "list.inactiveSelectionForeground": "#fff",
            "list.activeSelectionForeground": "#fff",
            "list.activeSelectionBackground": "#26007e",
            "list.focusBackground": "#2e5704"
          }
        }
      ]
    }
  ],
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
    "typescriptreact": "javascriptreact",
    "jsx-sublime-babel-tags": "javascriptreact"
  },
  "gitlens.menus": {
    "editor": false,
    "editorGroup": false,
    "editorTab": false,
    "explorer": {
      "clipboard": true,
      "compare": true,
      "history": true,
      "remote": true
    },
    "scmGroup": {
      "compare": true,
      "openClose": true,
      "stash": true,
      "stashInline": true
    },
    "scmItem": {
      "clipboard": true,
      "compare": true,
      "history": true,
      "remote": true,
      "stash": true
    }
  },
  "gitlab.customQueries": [
    {
      "name": "Issues assigned to me",
      "type": "issues",
      "scope": "assigned_to_me",
      "state": "opened",
      "noItemText": "There is no issue assigned to you."
    },
    {
      "name": "Merge requests assigned to me",
      "type": "merge_requests",
      "scope": "assigned_to_me",
      "state": "opened",
      "noItemText": "There is no MR assigned to you."
    }
  ],
  "editor.quickSuggestions": {
    "other": false,
    "comments": false,
    "strings": false
  },
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.colorTheme": "Moonlight II Italic"
}
