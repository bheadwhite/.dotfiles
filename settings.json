{
  "amVim.useSystemClipboard": true,
  "breadcrumbs.icons": false,
  "breadcrumbs.symbolSortOrder": "position",
  "clipboard-manager.avoidDuplicates": true,
  "clipboard-manager.maxClips": 500,
  "clipboard-manager.moveToTop": true,
  "clipboard-manager.onlyWindowFocused": false,
  "clipboard-manager.snippet.enabled": false,
  "diffEditor.renderIndicators": false,
  "diffEditor.renderSideBySide": true,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": true,
  "editor.cursorSurroundingLines": 5,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.definitionLinkOpensInPeek": false,
  "editor.experimental.stickyScroll.enabled": true,
  "editor.find.autoFindInSelection": "multiline",
  "editor.find.cursorMoveOnType": true,
  "editor.fontFamily": "Fira Code",
  "editor.fontSize": 14,
  "editor.formatOnSave": true,
  "editor.glyphMargin": false,
  "editor.gotoLocation.alternativeDefinitionCommand": "editor.action.referenceSearch.trigger",
  "editor.guides.bracketPairs": true,
  "editor.guides.bracketPairsHorizontal": false,
  "editor.guides.highlightActiveBracketPair": true,
  "editor.guides.highlightActiveIndentation": true,
  "editor.inlayHints.enabled": "on",
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,
  "editor.minimap.enabled": false,
  "editor.minimap.maxColumn": 100,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.showSlider": "always",
  "editor.minimap.size": "fill",
  "editor.multiCursorModifier": "alt",
  "editor.parameterHints.enabled": false,
  "editor.scrollbar.verticalScrollbarSize": 12,
  "editor.smoothScrolling": true,
  "editor.snippetSuggestions": "bottom",
  "editor.suggest.localityBonus": true,
  "editor.suggest.showSnippets": false,
  "editor.suggestOnTriggerCharacters": false,
  "editor.suggestSelection": "recentlyUsed",
  "editor.tabCompletion": "off",
  "editor.tabSize": 2,
  "editor.wordBasedSuggestions": false,
  "editor.wordBasedSuggestionsMode": "currentDocument",
  "emmet.showSuggestionsAsSnippets": true,
  "explorer.compactFolders": false,
  "explorer.openEditors.visible": 0,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.mergeEditor": false,
  "git.openDiffOnClick": true,
  "gitlab.instanceUrl": "https://git.tcncloud.net",
  "gitlens.statusBar.enabled": false,
  "http.systemCertificates": true,
  "javascript.preferences.importModuleSpecifier": "non-relative",
  "javascript.preferences.jsxAttributeCompletionStyle": "auto",
  "javascript.preferences.quoteStyle": "single",
  "javascript.suggest.names": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "problems.sortOrder": "position",
  "screencastMode.onlyKeyboardShortcuts": true,
  "search.searchOnType": false,
  "security.workspace.trust.untrustedFiles": "open",
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.tabs.enabled": false,
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.preferences.jsxAttributeCompletionStyle": "auto",
  "typescript.preferences.quoteStyle": "single",
  "typescript.preferences.useAliasesForRenames": false,
  "typescript.referencesCodeLens.showOnAllFunctions": true,
  "typescript.suggest.classMemberSnippets.enabled": false,
  "typescript.tsserver.log": "off",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "workbench.activityBar.visible": false,
  "workbench.colorTheme": "gruvboxConcoctis dark medium",
  "workbench.editor.enablePreviewFromCodeNavigation": true,
  "workbench.editor.labelFormat": "short",
  "workbench.iconTheme": "eq-material-theme-icons-darker",
  "workbench.list.automaticKeyboardNavigation": false,
  "workbench.panel.defaultLocation": "bottom",
  "workbench.panel.opensMaximized": "never",
  "workbench.settings.editor": "json",
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.sideBar.location": "left",
  "workbench.startupEditor": "none",
  "zenMode.centerLayout": false,
  "workbench.colorCustomizations": {
    // main background
    "badge.background": "#1a2b33",
    "banner.background": "#1a2b33",
    "breadcrumbPicker.background": "#1a2b33",
    "button.background": "#1a2b33",
    "editor.background": "#1a2b33",
    "editor.foldBackground": "#1a2b33",
    "editorGroup.emptyBackground": "#1a2b33",
    "editorGroupHeader.tabsBackground": "#1a2b33",
    "editorGutter.background": "#1a2b33",
    "editorHoverWidget.background": "#1a2b33",
    "editorInlayHint.background": "#1a2b33",
    "editorInlayHint.parameterBackground": "#1a2b33",
    "editorPane.background": "#1a2b33",
    "editorSuggestWidget.background": "#1a2b33",
    "editorWidget.background": "#1a2b33",
    "menu.background": "#1a2b33",
    "panel.background": "#1a2b33",
    "peekViewEditor.background": "#1a2b33",
    "peekViewEditorGutter.background": "#1a2b33",
    "sideBarSectionHeader.background": "#1a2b33",
    "tab.inactiveBackground": "#19272d",
    "tab.unfocusedActiveBackground": "#1a2b33",
    "tab.unfocusedInactiveBackground": "#1a2b33",
    "welcomePage.background": "#1a2b33",
    "welcomePage.tileBackground": "#1a2b33",
    "button.foreground": "#a6a4a7",
    "button.hoverBackground": "#1c3e49",
    // secondary color
    "notifications.background": "#10232b",
    "notificationToast.border": "#10232b",
    "breadcrumb.background": "#10232b",
    "terminal.background": "#10232b",
    "sideBar.background": "#10232b",
    //tertiary color
    "list.hoverBackground": "#1d3843",
    "titleBar.activeBackground": "#1d3843",

    //terminal text color
    "terminal.foreground": "#d1d1d1",

    //gruvbox concoctis hard theme colors
    // green : #8a984d
    // blue : #6dada0
    // orange : #cb723a
    // pink/violet: #925a69
    // sunset : #c6504d
    // light orange : #dca245

    "titleBar.inactiveBackground": "#455558",

    "tab.activeBackground": "#11303d",
    "tab.activeForeground": "#b7becd",
    "tab.inactiveForeground": "#7d93a9",

    "tab.unfocusedActiveForeground": "#635f5b",
    "tab.unfocusedInactiveForeground": "#635f5b",
    "editorCursor.foreground": "#ffffff",
    "editorSuggestWidget.selectedBackground": "#455558",
    //end background
    "editor.selectionBackground": "#ffffff23",
    "editor.rangeHighlightBackground": "#ffffff23",
    "gitDecoration.modifiedResourceForeground": "#249740",
    "gitDecoration.untrackedResourceForeground": "#ff8400",
    "editorLineNumber.activeForeground": "#c5c9ce",
    "editorLineNumber.foreground": "#46887d",
    "editorBracketHighlight.foreground6": "#8a984d",
    "editorBracketHighlight.foreground5": "#6dada0",
    "editorBracketHighlight.foreground4": "#cb723a",
    "editorBracketHighlight.foreground3": "#925a69",
    "editorBracketHighlight.foreground2": "#c6504d",
    // "mergeEditor.conflict.handled.minimapOverViewRuler": "#ff0000",
    "editorBracketHighlight.foreground1": "#dca245",
    "editorBracketMatch.background": "#1170ff88",
    "editorBracketMatch.border": "#ff8400",
    "editor.wordHighlightStrongBackground": "#3e4998",
    "editor.wordHighlightBackground": "#3e4998",
    "editor.findMatchBackground": "#56055e",
    "editor.findMatchHighlightBackground": "#a7508d97",
    "editorOverviewRuler.findMatchForeground": "#ff90de97",
    "editorOverviewRuler.bracketMatchForeground": "#a7508d97",
    "editorOverviewRuler.selectionHighlightForeground": "#a7508d97",
    "editor.selectionForeground": "#99eeff",
    "editorIndentGuide.activeBackground": "#1d76db",
    "list.inactiveSelectionForeground": "#fff",
    "list.activeSelectionForeground": "#fff",
    "list.activeSelectionBackground": "#26007e",
    "list.focusBackground": "#455558"
  },
  "macros.list": {
    "openScmFile": ["git.openFile", "git.closeAllDiffEditors"],
    "fastCursorDown": [
      {
        "command": "type",
        "args": {
          "text": "5"
        }
      },
      "amVim.down"
    ],
    "fastCursorUp": [
      {
        "command": "type",
        "args": {
          "text": "5"
        }
      },
      "amVim.up"
    ],
    "newLine": [
      {
        "command": "type",
        "args": {
          "text": "\n"
        }
      }
    ],
    "closeQuickOpen": [
      "workbench.action.closeQuickOpen",
      "workbench.action.focusActiveEditorGroup"
    ],
    "goPrevChange": [
      "workbench.action.editor.previousChange",
      "editor.action.dirtydiff.previous"
    ],
    "goNextChange": [
      "workbench.action.editor.nextChange",
      "editor.action.dirtydiff.next"
    ],
    "customFindInFiles": ["workbench.action.findInFiles", "list.focusDown"],
    "cDeleteText": [
      "deleteInsideWord",
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      {
        "command": "type",
        "args": {
          "text": "i"
        }
      }
    ],
    "indentSelectToBeginning": [
      "cursorEnd",
      "indentation-level-movement.selectUp",
      {
        "command": "type",
        "args": {
          "text": "0"
        }
      }
    ],
    "focusFind": [
      {
        "command": "type",
        "args": {
          "text": "i"
        }
      },
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      "actions.find"
    ],
    "openSCM": ["list.select"],
    "indentSelectToEnd": [
      {
        "command": "type",
        "args": {
          "text": "V"
        }
      },
      "indentation-level-movement.selectDown",
      "cursorEndSelect"
    ],
    "gitViewFile": [
      "list.selectAndPreserveFocus",
      {
        "command": "$delay",
        "args": {
          "delay": 50
        }
      },
      "workbench.action.focusFirstEditorGroup"
    ],
    "resetTree": [
      "workbench.files.action.collapseExplorerFolders",
      "workbench.files.action.refreshFilesExplorer"
    ]
  },
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
    "typescriptreact": "javascriptreact",
    "jsx-sublime-babel-tags": "javascriptreact"
  },
  "gitlens.menus": {
    "editor": false,
    "editorGroup": false,
    "editorTab": false,
    "explorer": {
      "clipboard": true,
      "compare": true,
      "history": true,
      "remote": true
    },
    "scmGroup": {
      "compare": true,
      "openClose": true,
      "stash": true,
      "stashInline": true
    },
    "scmItem": {
      "clipboard": true,
      "compare": true,
      "history": true,
      "remote": true,
      "stash": true
    }
  },
  "gitlab.customQueries": [
    {
      "name": "Issues assigned to me",
      "type": "issues",
      "scope": "assigned_to_me",
      "state": "opened",
      "noItemText": "There is no issue assigned to you."
    },
    {
      "name": "Merge requests assigned to me",
      "type": "merge_requests",
      "scope": "assigned_to_me",
      "state": "opened",
      "noItemText": "There is no MR assigned to you."
    }
  ],
  "gitlens.codeLens.recentChange.enabled": false,
  "gitlens.codeLens.authors.enabled": false,
  "liveshare.audio.joinCallBehavior": "accept",
  "editor.unicodeHighlight.allowedCharacters": {
    "–": true
  },
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "taskmarks.enableLabel": true,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "text.html.markdown.journal.task.open.bullet",
        "settings": {
          "foreground": "#FFFF00"
        }
      },
      {
        "scope": "text.html.markdown.journal.task.open.marker",
        "settings": {
          "foreground": "#FFFF00"
        }
      },
      {
        "scope": "text.html.markdown.journal.task.open.keyword",
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        "scope": "text.html.markdown.journal.task.open.text",
        "settings": {}
      },
      {
        "scope": "text.html.markdown.journal.task.completed.keyword",
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        "scope": "text.html.markdown.journal.task.completed.marker",
        "settings": {
          "foreground": "#AAAAAA"
        }
      },
      {
        "scope": "text.html.markdown.journal.task.completed.text",
        "settings": {
          "foreground": "#AAAAAA"
        }
      },
      {
        "scope": "text.html.markdown.journal.task.completed.bullet",
        "settings": {
          "foreground": "#FFFF00"
        }
      },
      {
        "scope": "text.html.markdown.journal.memo.keyword",
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        "scope": "text.html.markdown.journal.memo.bullet",
        "settings": {
          "foreground": "#FFFF00"
        }
      },
      {
        "scope": "text.html.markdown.journal.scope",
        "settings": {
          "foreground": "#FFFF00"
        }
      },
      {
        "scope": "text.html.markdown.journal.link.keyword",
        "settings": {
          "fontStyle": "italic"
        }
      },
      {
        "scope": "text.html.markdown.journal.link.bullet",
        "settings": {
          "foreground": "#FFFF00"
        }
      }
    ]
  }
}
