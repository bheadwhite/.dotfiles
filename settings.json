{
  "diffEditor.renderSideBySide": true,
  "debug.javascript.usePreview": false,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "on",
  "editor.suggestSelection": "recentlyUsed",
  "terminal.integrated.shell.osx": "/bin/zsh",
  "editor.cursorBlinking": "phase",
  "editor.tabCompletion": "off",
  "editor.cursorSmoothCaretAnimation": true,
  "editor.cursorSurroundingLines": 5,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.minimap.enabled": true,
  "editor.minimap.maxColumn": 100,
  "editor.fontFamily": "Fira Code",
  "editor.fontSize": 13,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.showSlider": "always",
  "editor.minimap.size": "fill",
  "editor.multiCursorModifier": "alt",
  "editor.parameterHints.enabled": false,
  "editor.snippetSuggestions": "bottom",
  "editor.tabSize": 2,
  "editor.wordBasedSuggestions": false,
  "explorer.openEditors.visible": 0,
  "gitlab.instanceUrl": "https://git.tcncloud.net",
  "gitlab.pipelineGitRemoteName": "https://git.tcncloud.net/m/neo/-/pipelines?page=1&scope=all&username=brent.whitehead",
  "gitlab.showPipelineUpdateNotifications": true,
  "githd.logView.displayExpressStatus": false,
  "githd.logView.expressMode": true,
  "gitlens.codeLens.enabled": false,
  "gitlens.recentChanges.highlight.locations": ["overview", "gutter", "line"],
  "gitlens.statusBar.enabled": false,
  "gitlens.views.compare.enabled": false,
  "gitlens.views.repositories.enabled": false,
  "gitlens.views.search.enabled": false,
  "go.useLanguageServer": false,
  "javascript.updateImportsOnFileMove.enabled": "always",
  "jestRunIt.jestConfigPath": "./operator/jest.config.js",
  "jestrunner.configPath": "./operator/jest.config.js", //tcn
  "openInGitHub.defaultBranch": "master",
  "openInGitHub.defaultRemote": "origin",
  "openInGitHub.excludeCurrentRevision": false,
  "openInGithub.maxBuffer": 512000,
  "prettier.jsxBracketSameLine": true,
  "prettier.jsxSingleQuote": true,
  "prettier.semi": false,
  "prettier.tabWidth": 2,
  "activeDocumentIndicator.opacity": 75,
  "synthwave84.brightness": 0.1,
  "synthwave84.disableGlow": true,
  "scoper.highlightColor": "",
  "scoper.braces": false,
  "scoper.squareBrackets": false,
  "scoper.parentheses": false,
  "telemetry.enableCrashReporter": false,
  "telemetry.enableTelemetry": false,
  "terminal.integrated.cursorBlinking": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "window.zoomLevel": 1,
  "workbench.activityBar.visible": false,
  "workbench.colorTheme": "Moonlight II Italic",
  "workbench.editor.showTabs": true,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.settings.enableNaturalLanguageSearch": false,
  "workbench.sideBar.location": "left",
  "workbench.startupEditor": "newUntitledFile",
  "zenMode.hideLineNumbers": false,
  "zenMode.hideStatusBar": false,
  "zenMode.hideTabs": false,
  "openInApplication.applications": {
    "html": ["Google Chrome"]
  },
  "workbench.colorCustomizations": {
    "editor.selectionBackground": "#ffffff23",
    "editor.rangeHighlightBackground": "#ffffff23",
    "editorBracketMatch.background": "#f008",
    "editorBracketMatch.border": "#f00",
    "editor.wordHighlightStrongBackground": "#3e4998",
    "editor.wordHighlightBackground": "#3e4998",
    "editor.findMatchBackground": "#282c34",
    "editor.findMatchHighlightBackground": "#06570997",
    "editor.selectionForeground": "#99eeff",
    "editorIndentGuide.activeBackground": "#1d76db",
    "list.inactiveSelectionForeground": "#fff",
    "list.activeSelectionForeground": "#fff",
    "list.activeSelectionBackground": "#26007e",
    "list.focusBackground": "#2e5704"
  },
  "files.exclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/*.js": {
      "when": "$(basename).ts"
    },
    // "**/node_modules/**": true,
    "**/tmp/**": true,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    // "**/node_modules": true,
    "**/bower_components": true,
    // "**/dist/**": true,
    "report*": true,
    "**/log/**": true,
    "**/.fdk/**": true,
    "**/.cache/**": true
  },
  "files.watcherExclude": {
    "**/.cache/**": true,
    "**/build_defs/**": true,
    //go files
    "**/commons/**": true,
    "**/k8s/**": true,
    "**/protos/matrix/**": true,
    "**/protos/p3/**": true,
    "**/.git/objects/**": true,
    "**/opctl/**": true,
    "**/services/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/tmp/**": true,
    "**/.yarn/**": true,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/bower_components": true,
    "**/dist/**": true,
    "**/log/**": true,
    "**/logs/**": true,
    "**/.fdk/**": true,
    "**/plz-out/**": true,
    "**/public/**": true
  },
  "search.exclude": {
    "**/.cache/**": true,
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/tmp/**": true,
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/bower_components": true,
    "**/dist/**": true,
    "**/log/**": true
  },
  "macros.list": {
    "goPrevChange": [
      "workbench.action.editor.previousChange",
      "editor.action.dirtydiff.previous"
    ],
    "goNextChange": [
      "workbench.action.editor.nextChange",
      "editor.action.dirtydiff.next"
    ],
    "selectInnerWord": [
      {
        "command": "type",
        "args": {
          "text": "v"
        }
      },
      {
        "command": "type",
        "args": {
          "text": "i"
        }
      },
      {
        "command": "type",
        "args": {
          "text": "w"
        }
      }
    ],
    "focusTerminal": [
      // "when": "!panelFocus"
      "workbench.action.focusPanel",
      "settings.cycle.termOn"
    ],
    "unFocusTerminal": [
      "workbench.action.focusFirstEditorGroup",
      "settings.cycle.termOff"
    ],
    "customSwitchAppHack": ["workbench.action.terminal.focus"],
    "customFindInFiles": [
      "workbench.action.findInFiles",
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      "list.focusDown"
    ],
    "customScmFocus": [
      "workbench.action.focusSideBar",
      "list.focusDown",
      "list.focusUp"
    ],
    "customY": [
      "copy-copy-paste.copy",
      {
        "command": "$delay",
        "args": {
          "delay": 10
        }
      },
      {
        "command": "type",
        "args": {
          "text": "y"
        }
      }
    ],
    "customJ": [
      {
        "command": "type",
        "args": {
          "text": ""
        }
      },
      "workbench.action.focusFirstEditorGroup"
    ],
    "indentSelectToBeginning": [
      "cursorEnd",
      "indentation-level-movement.selectUp",
      "cursorHomeSelect"
    ],
    "indentSelectToEnd": [
      {
        "command": "type",
        "args": {
          "text": "V"
        }
      },
      "indentation-level-movement.selectDown",
      "cursorEndSelect"
    ]
  },
  "settings.cycle": [
    {
      "id": "termOn",
      "overrideWorkspaceSettings": true,
      "values": [
        {
          "workbench.colorCustomizations": {
            "editor.selectionBackground": "#ffffff23",
            "editor.rangeHighlightBackground": "#ffffff23",
            "editorBracketMatch.background": "#f008",
            "editorBracketMatch.border": "#f00",
            "editor.wordHighlightStrongBackground": "#3e4998",
            "editor.wordHighlightBackground": "#3e4998",
            "editor.findMatchBackground": "#282c34",
            "editor.findMatchHighlightBackground": "#06570997",
            "editor.selectionForeground": "#99eeff",
            "editorIndentGuide.activeBackground": "#1d76db",
            "list.inactiveSelectionForeground": "#fff",
            "list.activeSelectionForeground": "#fff",
            "list.activeSelectionBackground": "#26007e",
            "list.focusBackground": "#2e5704",

            "panel.background": "#000",
            "terminal.border": "#ff0000"
          }
        }
      ]
    },
    {
      "id": "termOff",
      "overrideWorkspaceSettings": true,
      "values": [
        {
          "workbench.colorCustomizations": {
            "editor.selectionBackground": "#ffffff23",
            "editor.rangeHighlightBackground": "#ffffff23",
            "editorBracketMatch.background": "#f008",
            "editorBracketMatch.border": "#f00",
            "editor.wordHighlightStrongBackground": "#3e4998",
            "editor.wordHighlightBackground": "#3e4998",
            "editor.findMatchBackground": "#282c34",
            "editor.findMatchHighlightBackground": "#06570997",
            "editor.selectionForeground": "#99eeff",
            "editorIndentGuide.activeBackground": "#1d76db",
            "list.inactiveSelectionForeground": "#fff",
            "list.activeSelectionForeground": "#fff",
            "list.activeSelectionBackground": "#26007e",
            "list.focusBackground": "#2e5704"
          }
        }
      ]
    }
  ],
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
    "typescript": "typescriptreact",
    "typescriptreact": "javascriptreact",
    "jsx-sublime-babel-tags": "javascriptreact"
  },
  "gitlens.menus": {
    "editor": false,
    "editorGroup": false,
    "editorTab": false,
    "explorer": {
      "clipboard": true,
      "compare": true,
      "history": true,
      "remote": true
    },
    "scmGroup": {
      "compare": true,
      "openClose": true,
      "stash": true,
      "stashInline": true
    },
    "scmItem": {
      "clipboard": true,
      "compare": true,
      "history": true,
      "remote": true,
      "stash": true
    }
  },
  "gitlab.customQueries": [
    {
      "name": "Issues assigned to me",
      "type": "issues",
      "scope": "assigned_to_me",
      "state": "opened",
      "noItemText": "There is no issue assigned to you."
    },
    // {
    //   "name": "Issues created by me",
    //   "type": "issues",
    //   "scope": "created_by_me",
    //   "state": "opened",
    //   "noItemText": "There is no issue created by you."
    // },
    {
      "name": "Merge requests assigned to me",
      "type": "merge_requests",
      "scope": "assigned_to_me",
      "state": "opened",
      "noItemText": "There is no MR assigned to you."
    }
    // {
    //   "name": "Merge requests created by me",
    //   "type": "merge_requests",
    //   "scope": "created_by_me",
    //   "state": "opened",
    //   "noItemText": "There is no MR created by you."
    // },
    // {
    //   "name": "All project merge requests",
    //   "type": "merge_requests",
    //   "scope": "all",
    //   "state": "opened",
    //   "noItemText": "The project has no merge requests"
    // }
  ],
  "editor.renameOnType": true,
  "editor.quickSuggestions": {
    "other": false,
    "comments": false,
    "strings": false
  },
  "go.formatTool": "goimports",
  "editor.foldingStrategy": "indentation",
  "gitlens.mode.active": "zen"
}
