// Place your key bindings in this file to override the defaults
[
  // #region --------------------------------------------- REMOVED
  {
    "key": "cmd+q",
    "command": "-workbench.action.quit"
  },
  {
    "key": "ctrl+j",
    "command": "-editor.action.joinLines",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+k",
    "command": "-deleteAllRight",
    "when": "textInputFocus && !editorReadonly"
  },
  {
    "key": "cmd+j",
    "command": "-workbench.action.togglePanel"
  },
  {
    "key": "cmd+f",
    "command": "-actions.find"
  },
  {
    "key": "alt+f3",
    "command": "-editor.action.dirtydiff.next",
    "when": "editorTextFocus"
  },
  {
    "key": "shift+alt+f3",
    "command": "-editor.action.dirtydiff.previous",
    "when": "editorTextFocus"
  },
  {
    "key": "shift+cmd+w",
    "command": "-workbench.action.closeWindow"
  },
  {
    "key": "shift+cmd+g",
    "command": "-editor.action.previousMatchFindAction",
    "when": "editorFocus"
  },
  {
    "key": "shift+alt+cmd+c",
    "command": "-copyRelativeFilePath",
    "when": "!editorFocus"
  },
  // #endregion

  // #region ---------------------------------------------- WINDOWS/PANES/EDITORS
  {
    "key": "enter",
    "command": "workbench.action.keepEditor",
    "when": "editorFocus && !editorPinned"
  },
  {
    "key": "shift+cmd+g",
    "command": "workbench.scm.focus"
  },
  {
    "key": "cmd+1",
    "command": "workbench.action.focusFirstEditorGroup"
  },
  {
    "key": "cmd+l",
    "command": "workbench.action.focusFirstEditorGroup",
    "when": "sideBarFocus"
  },
  {
    "key": "ctrl+,",
    "command": "workbench.action.moveEditorLeftInGroup"
  },
  {
    "key": "ctrl+.",
    "command": "workbench.action.moveEditorRightInGroup"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.nextEditor"
  },
  {
    "key": "ctrl+h",
    "command": "workbench.action.previousEditor"
  },
  {
    "key": "shift+cmd+-",
    "command": "workbench.action.decreaseViewSize"
  },
  {
    "key": "shift+cmd+=",
    "command": "workbench.action.increaseViewSize"
  },
  {
    "key": "shift+j",
    "command": "scrollLineDown",
    "when": "textInputFocus && amVim.mode != 'INSERT' && !renameInputVisible"
  },
  {
    "key": "shift+k",
    "command": "scrollLineUp",
    "when": "textInputFocus && amVim.mode != 'INSERT' && !renameInputVisible"
  },
  {
    "key": "shift+,",
    "command": "workbench.action.focusLeftGroup",
    "when": "textInputFocus && !renameInputVisible && amVim.mode != 'INSERT'"
  },
  {
    "key": "shift+.",
    "command": "workbench.action.focusRightGroup",
    "when": "textInputFocus && !renameInputVisible && amVim.mode != 'INSERT'"
  },
  {
    "key": "shift+m",
    "command": "cursorMove",
    "args": {
      "to": "viewPortCenter"
    },
    "when": "textInputFocus && !renameInputVisible && amVim.mode != 'INSERT' && !panelFocus"
  },
  // #endregion

  // #region ---------------------------------------------- LINES
  {
    "key": "shift+alt+j",
    "command": "editor.action.copyLinesDownAction",
    "when": "editorTextFocus && !editorReadonly && amVim.mode != 'INSERT'"
  },
  {
    "key": "shift+alt+k",
    "command": "editor.action.copyLinesUpAction",
    "when": "editorTextFocus && !editorReadonly && amVim.mode != 'INSERT'"
  },
  {
    "key": "ctrl+j",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+k",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "cmd+q",
    "command": "editor.action.outdentLines",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "cmd+r",
    "command": "editor.action.indentLines"
  },
  // #endregion

  // #region ------------------------- LISTS/BREADCRUMBS/QUICKOPEN/EXPLORER-NA
  {
    "key": "alt+k",
    "command": "list.focusUp",
    "when": "listFocus"
  },
  {
    "key": "alt+j",
    "command": "list.focusDown",
    "when": "listFocus"
  },
  {
    "key": "alt+shift+k",
    "command": "list.focusUp",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "alt+j",
    "command": "list.focusDown",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "alt+h",
    "command": "list.collapse",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "alt+l",
    "command": "list.expand",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "enter",
    "command": "list.select",
    "when": "listFocus && !inputFocus && !inDebugRepl"
  },
  {
    "key": "space",
    "command": "breadcrumbs.revealFocused",
    "when": "breadcrumbsActive && breadcrumbsVisible && !inputFocus"
  },
  {
    "key": "alt+shift+enter",
    "command": "breadcrumbs.revealFocused",
    "when": "breadcrumbsActive && breadcrumbsVisible"
  },
  {
    "key": "alt+k",
    "command": "breadcrumbs.focusAndSelect",
    "when": "breadcrumbsPossible && editorTextFocus && !suggestWidgetVisible"
  },
  {
    "key": "alt+j",
    "command": "breadcrumbs.focusAndSelect",
    "when": "breadcrumbsPossible && editorTextFocus && !suggestWidgetVisible"
  },
  {
    "key": "alt+j",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "inQuickOpen"
  },
  {
    "key": "alt+k",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickOpen"
  },
  // #endregion

  // #region ---------------------------------------------- CURSOR
  {
    "key": "shift+cmd+l",
    "command": "cursorEndSelect",
    "when": "textInputFocus"
  },
  {
    "key": "cmd+l",
    "command": "cursorEnd",
    "when": "textInputFocus"
  },
  {
    "key": "cmd+h",
    "command": "cursorHome",
    "when": "textInputFocus"
  },
  {
    "key": "alt+l",
    "command": "cursorWordEndRight",
    "when": "textInputFocus"
  },
  {
    "key": "alt+h",
    "command": "cursorWordStartLeft",
    "when": "textInputFocus"
  },
  {
    "key": "ctrl+alt+cmd+j",
    "command": "indentation-level-movement.moveDown",
    "when": "amVim.mode != 'INSERT'"
  },
  {
    "key": "ctrl+alt+cmd+k",
    "command": "indentation-level-movement.moveUp",
    "when": "amVim.mode != 'INSERT'"
  },
  {
    "key": "ctrl+cmd+shift+j",
    "command": "macros.indentSelectToEnd",
    "when": "amVim.mode != 'INSERT'"
  },
  {
    "key": "ctrl+cmd+shift+k",
    "command": "macros.indentSelectToBeginning",
    "when": "amVim.mode != 'INSERT'"
  },
  {
    "key": "ctrl+m",
    "command": "cursorMove",
    "args": {
      "to": "viewPortCenter"
    }
  },

  //jumping
  {
    "key": "tab",
    "command": "editor.action.jumpToBracket",
    "when": "amVim.mode != 'INSERT' && editorTextFocus"
  },
  {
    "key": "cmd+.",
    "command": "extension.embraceAngleBrackets",
    "when": "amVim.mode == 'VISUAL'"
  },
  {
    "key": "cmd+]",
    "command": "extension.embraceSquareBrackets",
    "when": "amVim.mode == 'VISUAL'"
  },
  {
    "key": "cmd+shift+]",
    "command": "extension.embraceCurlyBrackets",
    "when": "amVim.mode == 'VISUAL'"
  },
  {
    "key": "cmd+shift+'",
    "command": "extension.embraceDoubleQuotes",
    "when": "amVim.mode == 'VISUAL'"
  },
  {
    "key": "cmd+'",
    "command": "extension.embraceSingleQuotes",
    "when": "amVim.mode == 'VISUAL'"
  },
  {
    "key": "cmd+shift+0",
    "command": "extension.embraceParenthesis",
    "when": "amVim.mode == 'VISUAL'"
  },
  // #endregion

  // #region -------------------------------------------------- SUGGESTIONS
  {
    "key": "alt+space",
    "command": "editor.action.triggerSuggest",
    "when": "editorHasCompletionItemProvider && textInputFocus && !editorReadonly"
  },
  {
    "key": "alt+k",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetVisible"
  },
  {
    "key": "alt+j",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetVisible"
  },
  // #endregion

  // #region ---------------------------------------------- LANGUAGE SERVER
  {
    "key": "cmd+i",
    "command": "editor.action.revealDefinition"
  },
  // #endregion

  // #region --------------------------------------------------  VSCODE-SPECIFIC
  {
    "key": "shift+l",
    "command": "workbench.action.editor.nextChange",
    "when": "editorFocus && !findWidgetVisible && !inQuickOpen && !renameInputVisible && amVim.mode != 'INSERT'"
  },
  {
    "key": "shift+h",
    "command": "workbench.action.editor.previousChange",
    "when": "editorFocus && !findWidgetVisible && !inQuickOpen && !renameInputVisible && amVim.mode != 'INSERT'"
  },
  {
    "key": "ctrl+cmd+r",
    "command": "copyRelativeFilePath"
  },
  // #endregion

  // #region ------------------------------------------- VIM
  {
    "key": "l",
    "command": "cursorRight",
    "when": "editorReadonly"
  },
  {
    "key": "h",
    "command": "cursorLeft",
    "when": "editorReadonly"
  },
  {
    "key": "k",
    "command": "cursorUp",
    "when": "editorReadonly"
  },
  {
    "key": "j",
    "command": "cursorDown",
    "when": "editorReadonly"
  },
  {
    "key": "s",
    "command": "type",
    "args": { "text": "v" },
    "when": "amVim.mode != 'INSERT' && !findWidgetVisible && !inQuickOpen && editorFocus && !renameInputVisible"
  },
  {
    "key": "shift+s",
    "command": "cursorEndSelect",
    "when": "amVim.mode != 'INSERT' && !findWidgetVisible && !inQuickOpen && editorFocus && !renameInputVisible"
  },
  {
    "key": "ctrl+h",
    "command": "workbench.action.terminal.focusPreviousPane",
