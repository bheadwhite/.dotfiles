// Place your key bindings in this file to override the defaults
[
  // #region --------------------------------------------- REMOVED
  {
    "key": "cmd+q",
    "command": "-workbench.action.quit"
  },
  {
    "key": "ctrl+j",
    "command": "-editor.action.joinLines",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+k",
    "command": "-deleteAllRight",
    "when": "textInputFocus && !editorReadonly"
  },
  {
    "key": "cmd+j",
    "command": "-workbench.action.togglePanel"
  },
  {
    "key": "alt+f3",
    "command": "-editor.action.dirtydiff.next",
    "when": "editorTextFocus"
  },
  {
    "key": "shift+alt+f3",
    "command": "-editor.action.dirtydiff.previous",
    "when": "editorTextFocus"
  },
  {
    "key": "shift+cmd+w",
    "command": "-workbench.action.closeWindow"
  },
  {
    "key": "shift+cmd+g",
    "command": "-editor.action.previousMatchFindAction",
    "when": "editorFocus"
  },
  {
    "key": "shift+alt+cmd+c",
    "command": "-copyRelativeFilePath",
    "when": "!editorFocus"
  },
  // #endregion

  // #region ---------------------------------------------- WINDOWS/PANES/EDITORS
  {
    "key": "enter",
    "command": "workbench.action.keepEditor",
    "when": "editorFocus && !activeEditorIsNotPreview && !listFocus"
  },
  {
    "key": "shift+cmd+g",
    "command": "workbench.scm.focus",
    "when": "!findWidgetVisible && !view.workbench.scm.visible"
  },
  {
    "key": "cmd+1",
    "command": "workbench.action.focusFirstEditorGroup"
  },
  {
    "key": "shift+enter",
    "command": "workbench.action.focusFirstEditorGroup"
  },
  {
    "key": "cmd+l",
    "command": "workbench.action.focusFirstEditorGroup",
    "when": "sideBarFocus"
  },
  {
    "key": "ctrl+,",
    "command": "workbench.action.moveEditorLeftInGroup"
  },
  {
    "key": "ctrl+.",
    "command": "workbench.action.moveEditorRightInGroup"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.nextEditor"
  },
  {
    "key": "ctrl+h",
    "command": "workbench.action.previousEditor"
  },
  {
    "key": "shift+cmd+-",
    "command": "workbench.action.decreaseViewSize"
  },
  {
    "key": "shift+cmd+=",
    "command": "workbench.action.increaseViewSize"
  },
  {
    "key": "shift+j",
    "command": "scrollLineDown",
    "when": "textInputFocus && amVim.mode != 'INSERT' && !renameInputVisible"
  },
  {
    "key": "shift+k",
    "command": "scrollLineUp",
    "when": "textInputFocus && amVim.mode != 'INSERT' && !renameInputVisible"
  },
  {
    "key": "shift+m",
    "command": "cursorMove",
    "args": {
      "to": "viewPortCenter"
    },
    "when": "textInputFocus && !renameInputVisible && amVim.mode != 'INSERT' && !panelFocus"
  },
  // #endregion

  // #region ---------------------------------------------- LINES
  {
    "key": "shift+alt+j",
    "command": "editor.action.copyLinesDownAction",
    "when": "editorTextFocus && !editorReadonly && amVim.mode != 'INSERT'"
  },
  {
    "key": "shift+alt+k",
    "command": "editor.action.copyLinesUpAction",
    "when": "editorTextFocus && !editorReadonly && amVim.mode != 'INSERT'"
  },
  {
    "key": "ctrl+j",
    "command": "editor.action.moveLinesDownAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "ctrl+k",
    "command": "editor.action.moveLinesUpAction",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "cmd+q",
    "command": "editor.action.outdentLines",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "cmd+r",
    "command": "editor.action.indentLines"
  },
  // #endregion

  // #region ------------------------- LISTS/BREADCRUMBS/QUICKOPEN/EXPLORER-NA
  {
    "key": "alt+k",
    "command": "list.focusUp",
    "when": "listFocus"
  },
  {
    "key": "alt+j",
    "command": "list.focusDown",
    "when": "listFocus"
  },
  {
    "key": "alt+shift+k",
    "command": "list.focusUp",
    "when": "listFocus && !inputFocus"
