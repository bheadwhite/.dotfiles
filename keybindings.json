  },
  {
    "key": "alt+k",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickOpen"
  },
  // #endregion

  // #region ---------------------------------------------- CURSOR
  {
    "key": "cmd+l",
    "command": "type",
    "args": { "text": "$" },
    "when": "textInputFocus && amVim.mode != 'INSERT'"
  },
  {
    "key": "cmd+h",
    "command": "type",
    "args": { "text": "^" },
    "when": "textInputFocus && amVim.mode != 'INSERT'"
  },
  {
    "key": "cmd+l",
    "command": "cursorEnd",
    "when": "textInputFocus && amVim.mode == 'INSERT'"
  },
  {
    "key": "cmd+h",
    "command": "cursorHome",
    "when": "textInputFocus && amVim.mode == 'INSERT'"
  },
  {
    "key": "alt+l",
    "command": "type",
    "args": { "text": "e" },
    "when": "textInputFocus && amVim.mode != 'INSERT'"
  },
  {
    "key": "alt+h",
    "command": "type",
    "args": { "text": "b" },
    "when": "textInputFocus && amVim.mode != 'INSERT'"
  },
  {
    "key": "alt+l",
    "command": "cursorWordEndRight",
    "when": "textInputFocus && amVim.mode == 'INSERT'"
  },
  {
    "key": "alt+h",
    "command": "cursorWordStartLeft",
    "when": "textInputFocus && amVim.mode == 'INSERT'"
